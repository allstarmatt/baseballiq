# ─────────────────────────────────────────────────────────────────────────────
# BaseballIQ — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it contains secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_PORT=8000

# ── Database (Supabase Postgres) ──────────────────────────────────────────────
# Get this from: supabase.com → your project → Settings → Database → URI
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres

# ── The Odds API ──────────────────────────────────────────────────────────────
# Sign up at: the-odds-api.com
# Free tier: 500 requests/month. Paid starts at ~$50/mo for real-time.
ODDS_API_KEY=f72f38263cf9001a198095426f412ee6
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# ── Weather API (Tomorrow.io) ─────────────────────────────────────────────────
# Sign up at: tomorrow.io — free tier is sufficient for Phase 1
WEATHER_API_KEY=H6s2V3FZiRvd9XPBP1ldwoRydQ7BxGRh
WEATHER_API_BASE_URL=https://api.tomorrow.io/v4

# ── Redis Cache (optional but recommended) ────────────────────────────────────
# Upstash.com has a free hosted Redis tier
REDIS_URL=redis://localhost:6379

# ── MLB Stats API ─────────────────────────────────────────────────────────────
# No key needed — it's free and public
MLB_API_BASE_URL=https://statsapi.mlb.com/api/v1

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
